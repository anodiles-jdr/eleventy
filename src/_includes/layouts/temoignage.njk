---
layout: layouts/base.njk
---

{# Layout pour l'affichage d'un témoignage individuel #}
<article class="temoignage">

  {# En-tête de la fiche avec les métadonnées du témoignage #}
  <header class="fiche">

    <h1>{{ temoignageDe }}</h1>

    <dl>

      <dt>Surnom</dt>
      <dd>{{ surnom }}</dd>

      <dt>Origine</dt>
      <dd>{{ origine }}</dd>

      <dt>Faction</dt>
      <dd>{{ faction }}</dd>

      <dt>Période</dt>
      <dd>{{ periode }}</dd>

    </dl>

  </header>

  {# Corps principal du témoignage #}
  <section class="contenu">
    {{ content | safe }}
  </section>

  {# Lien de retour vers la liste des archives si configuré #}
  {% if retour %}
<nav class="retour">
 <a href="{{ retour.url | url }}">← Retour aux archives</a>
</nav>
{% endif %}


</article>