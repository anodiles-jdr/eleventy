---
layout: layouts/base.njk
---

<section class="hero">

  <h2>
    Archives des témoins
  </h2>

  <p>
    Fragments de mémoire recueillis après la Révolution.
  </p>

</section>

<section id="temoignages">

  <h2>Témoignages</h2>

  <div class="cards">

    {% for temoignage in collections.temoignages %}
      <article class="card">

        <h3>
          <a href="{{ temoignage.url }}">{{ temoignage.data.temoignageDe }}</a>
        </h3>

        <p>{{ temoignage.data.surnom }}</p>

        <small>{{ temoignage.data.faction }}</small>

      </article>
    {% endfor %}

  </div>

</section>
